# https://www.chezmoi.io/reference/special-files/chezmoi-format-tmpl/

{{- /* Boolean feature tags */ -}}
{{- $encryption := false }}{{/* true if encryption is used */}}
{{- $ephemeral := false }}{{/* true if this machine is ephemeral, e.g. a cloud or VM instance */}}
{{- $work := false }}{{/* true if this machine is a work machine */}}
{{- $headless := false }}{{/* true if this machine does not have a screen and keyboard */}}
{{- $personal := false }}{{/* true if this machine should have personal secrets */}}
{{- "" }}

{{- /* Checks if running interactively */ -}}
{{- $codespaces := env "CODESPACES" | not | not }}
{{- $interactive := stdinIsATTY }}

{{- /* Detects GitHub Codespaces, VSCode Remotes, Containers, etc. */ -}}
{{- if or $codespaces (env "REMOTE_CONTAINERS_IPC") (eq .chezmoi.username "root" "vscode") }}
{{-   $ephemeral = true }}
{{-   $headless = true }}
{{- end }}

{{- if not $ephemeral }}
{{-   if $interactive }}
{{-     $encryption = promptStringOnce . "encryption" "age public key" }}
{{-     $personal = promptBoolOnce . "personal" "personal" }}
{{-     $work = promptBoolOnce . "work" "work" }}
{{-   else }}
{{-     $headless = true }}
{{-   end }}
{{- end }}

{{- $name := "" }}
{{- if (env "GIT_CONFIG_USER_NAME") }}
{{-   $name = env "GIT_CONFIG_USER_NAME" }}
{{- else if $interactive }}
{{-   $name = promptStringOnce . "name" "name" }}
{{- else if hasKey . "name" }}
{{-   $name = .name }}
{{- end }}

{{- $email := "" }}
{{- if (env "GIT_CONFIG_USER_EMAIL") }}
{{-   $email = env "GIT_CONFIG_USER_EMAIL" }}
{{- else if $interactive }}
{{-   $email = promptStringOnce . "email" "email" }}
{{- else if hasKey . "email" }}
{{-   $email = .email }}
{{- end }}

{{- if $interactive }}
{{-   writeToStdout "💡 Tip: you can re-enter your data with `chezmoi init --data=false`.\n" }}
{{- end }}

{{- /***/ -}}

sourceDir: {{ .chezmoi.sourceDir | quote }}

{{- if $encryption }}
encryption: age
age:
  identity: {{ printf "%s/.config/chezmoi/key" .chezmoi.destDir | quote }}
  recipient: {{ $encryption | quote }}
{{- end }}

edit:
  command: code
  args:
  - --wait

diff:
  command: code
  args:
  - --wait
  - --diff

merge:
  command: bash
  args:
  - -c
  - |
    cp {{ "{{" }} .Target | quote {{ "}}" }} {{ "{{" }} printf "%s.base" .Target | quote {{ "}}" }} && \
    code --new-window --wait --merge \
      {{ "{{" }} .Destination | quote {{ "}}" }} \
      {{ "{{" }} .Target | quote {{ "}}" }} \
      {{ "{{" }} printf "%s.base" .Target | quote {{ "}}" }} \
      {{ "{{" }} .Source | quote {{ "}}" }}

data:
  ephemeral: {{ $ephemeral }}
  work: {{ $work }}
  headless: {{ $headless }}
  personal: {{ $personal }}
  codespaces: {{ $codespaces }}

  encryption: {{ $encryption | quote }}

  name: {{ $name | quote }}
  email: {{ $email | quote }}
